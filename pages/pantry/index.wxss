/* FitPulse Inventory - Pro Long-Strip Board */

page {
  background-color: #ffffff;
  color: #1a1a1a;
  font-family: -apple-system, "Inter", sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container { display: flex; flex-direction: column; min-height: 100vh; }

/* --- Precision Fixed Header --- */
.safe-header {
  background: #ffffff;
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  border-bottom: 1rpx solid #f2f2f7;
}

.header-main {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 确保标题纵向排列并缩小字号避让胶囊按钮 */
.header-title-group {
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.page-title { 
  font-size: 36rpx; 
  font-weight: 700; 
  letter-spacing: -0.04em; 
  line-height: 1.2;
}
.page-label { 
  font-size: 18rpx; 
  font-weight: 800; 
  color: #8a8a8e; 
  letter-spacing: 0.1em; 
  line-height: 1.2;
}
.add-btn-minimal {
  background: #000;
  color: #fff;
  padding: 0 24rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
}
.add-btn-minimal text { font-size: 18rpx; font-weight: 900; letter-spacing: 0.05em; }

/* --- Pro Inventory Strips --- */
.pantry-scroll-pro {
  padding: 40rpx;
  box-sizing: border-box;
}

.inventory-strip {
  background: #ffffff;
  border: 1rpx solid #f2f2f7;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  position: relative;
}

.strip-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.item-meta { display: flex; flex-direction: column; }
.item-cat { font-size: 16rpx; font-weight: 900; color: #aeaeb2; text-transform: uppercase; margin-bottom: 4rpx; }
.item-name { font-size: 34rpx; font-weight: 800; letter-spacing: -0.02em; }

.item-weight { display: flex; align-items: baseline; }
.val { font-size: 32rpx; font-weight: 800; }
.unit { font-size: 18rpx; color: #c7c7cc; margin-left: 4rpx; }

.strip-bar-shell {
  height: 6rpx;
  background: #f2f2f7;
  border-radius: 3rpx;
  overflow: hidden;
}

.strip-bar-fill {
  height: 100%;
  background: #000;
  border-radius: 3rpx;
  transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.depleted { opacity: 0.5; }
.depleted-tag {
  position: absolute;
  top: 32rpx; right: 32rpx;
  font-size: 14rpx; font-weight: 900; color: #ff3b30;
  border: 1rpx solid #ff3b30; padding: 2rpx 8rpx; border-radius: 4rpx;
}

/* --- Centered Pro Modal --- */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.15);
  backdrop-filter: blur(15px);
  z-index: 2000;
  display: flex; align-items: flex-end;
}

.modal-content-pro {
  width: 100%;
  background: #fff;
  border-radius: 54rpx 54rpx 0 0;
  padding: 60rpx 40rpx calc(60rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  display: flex; flex-direction: column;
}

.modal-top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; }
.modal-title-bold { font-size: 40rpx; font-weight: 900; }

.modal-body-scroll { flex: 1; }

.section-tag { font-size: 16rpx; font-weight: 900; color: #aeaeb2; letter-spacing: 0.1em; margin-bottom: 24rpx; display: block; }

.cat-pill-grid { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 40rpx; }
.cat-pill { padding: 12rpx 28rpx; font-size: 22rpx; font-weight: 800; background: #f2f2f7; color: #8e8e93; border-radius: 14rpx; }
.cat-pill.active { background: #000; color: #fff; }

.input-row-pro { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f2f2f7; }
.input-row-pro text { font-size: 26rpx; font-weight: 700; }
.input-row-pro input { text-align: right; font-size: 28rpx; font-weight: 800; width: 300rpx; }

.macro-group { display: flex; gap: 10rpx; }
.macro-group input { width: 60rpx; background: #f2f2f7; padding: 8rpx; border-radius: 10rpx; text-align: center; }

/* Centered Confirm Button */
.modal-footer-centered {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
}

.confirm-entry-btn {
  background: #000;
  color: #fff;
  height: 104rpx;
  width: 70% !important;
  border-radius: 28rpx;
  font-weight: 900;
  font-size: 26rpx;
  letter-spacing: 0.1em;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}
