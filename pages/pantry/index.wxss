.container {
  padding: 40rpx 30rpx;
  background-color: #f8f9fa;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* Tab 导航样式 */
.tab-header {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 10rpx;
}

.tab-item {
  position: relative;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #adb5bd;
  transition: all 0.3s ease;
}

.tab-active {
  color: #212529;
  font-weight: bold;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #07c160;
  border-radius: 10rpx;
}

/* 输入卡片 */
.input-card {
  background: #ffffff;
  padding: 60rpx 40rpx;
  border-radius: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.03);
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 28rpx;
  color: #adb5bd;
  margin-bottom: 20rpx;
}

/* Picker 样式 */
.picker-box {
  background: #f1f3f5;
  padding: 12rpx 30rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: #495057;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #adb5bd;
}

.input-box {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.main-input {
  width: 100%;
  height: 120rpx;
  font-size: 88rpx;
  font-weight: 600;
  color: #212529;
  text-align: center;
}

.ph-style { color: #e9ecef; }

.input-line {
  width: 120rpx;
  height: 6rpx;
  border-radius: 10rpx;
  margin-top: 10rpx;
}

.line-orange { background: linear-gradient(90deg, #ff9800, #ff5722); }
.line-blue { background: linear-gradient(90deg, #2196f3, #00bcd4); }

.input-unit {
  font-size: 32rpx;
  color: #495057;
  margin-top: 20rpx;
  font-weight: 500;
}

/* 结果卡片 */
.result-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.res-card {
  flex: 1;
  padding: 40rpx 20rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 颜色 */
.weight-bg { background-color: #e8f5e9; }
.carb-bg { background-color: #fff3e0; }
.protein-bg { background-color: #e3f2fd; width: 100%; }

.res-label {
  font-size: 26rpx;
  color: #6c757d;
  margin-bottom: 24rpx;
}

.res-value-wrap {
  display: flex;
  align-items: baseline;
}

.res-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #212529;
}

.res-unit {
  font-size: 24rpx;
  color: #495057;
  margin-left: 6rpx;
}

/* 动画 */
.fade-in {
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.5s ease;
}
.show {
  opacity: 1;
  transform: translateY(0);
}

.footer {
  margin-top: auto;
  padding: 40rpx 0;
  text-align: center;
}
.footer text {
  font-size: 22rpx;
  color: #ced4da;
  letter-spacing: 2rpx;
}
