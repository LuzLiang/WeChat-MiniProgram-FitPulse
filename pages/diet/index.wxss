/**
 * FitPulse Master Refactoring
 * Philosophies: Kenya Hara (Emptiness), Massimo Vignelli (Order), Paul Rand (Drama)
 */

.container {
  padding: 60rpx 40rpx;
  background-color: #ffffff;
  height: 100vh;
  display: flex;
  flex-direction: column;
  font-family: -apple-system, "DIN Alternate", "Helvetica Neue", sans-serif;
  box-sizing: border-box;
}

/* 一、建立绝对的几何与网格秩序 (Massimo Vignelli) */
.header-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  width: 100%;
  margin-bottom: 80rpx;
  flex-shrink: 0;
}

.header-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #000;
  text-transform: uppercase;
}

.mode-text-btn {
  font-size: 24rpx;
  font-weight: 500;
  color: #999;
  display: flex;
  align-items: center;
}

.minimal-arrow {
  font-size: 20rpx;
  margin-left: 8rpx;
  color: #ccc;
  font-weight: 300;
}

.reset-symbol {
  font-size: 36rpx;
  color: #eee;
  font-weight: 300;
}

/* 进度环网格：纯粹几何对抗 */
.rings-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 100rpx;
  flex-shrink: 0;
}

.ring-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.ring {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
}

.ring::after {
  content: '';
  width: 92rpx;
  height: 92rpx;
  background: #fff;
  border-radius: 50%;
}

.ring-data {
  text-align: center;
}

.label {
  display: block;
  font-size: 18rpx;
  color: #ccc;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.value {
  font-size: 24rpx;
  font-weight: 600;
  color: #000;
}

/* 二、剥离视觉冗余 (Kenya Hara) */
.main-stage {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cat-nav {
  white-space: nowrap;
  width: 100%;
  height: 60rpx;
  margin-bottom: 40rpx;
}

.nav-item {
  display: inline-block;
  font-size: 26rpx;
  color: #ccc;
  margin-right: 48rpx;
  font-weight: 500;
  transition: color 0.3s ease;
}

.nav-item.active {
  color: #000;
  font-weight: 700;
}

.food-selector-box {
  margin-bottom: 60rpx;
}

.food-text-picker {
  font-size: 32rpx;
  color: #000;
  font-weight: 600;
  display: flex;
  align-items: center;
}

/* 视觉黑洞与数据引力 (Paul Rand) */
.input-focus-group {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  width: 100%;
}

.input-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 8rpx;
  gap: 8rpx; /* 缩紧数字与单位间距 */
}

.numeric-giant {
  font-size: 180rpx;
  font-weight: 800;
  height: 200rpx;
  text-align: center;
  width: 320rpx; /* 稍微缩窄宽度以增强聚集感 */
  color: #000;
  letter-spacing: -4rpx;
}

.giant-placeholder {
  color: #f5f5f5;
}

.unit-label {
  font-size: 40rpx;
  color: #eee;
  font-weight: 500;
}

.nutrient-gravity-bar {
  display: flex;
  gap: 40rpx;
}

.nutrient-gravity-bar text {
  font-size: 22rpx;
  color: #ccc;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 三、注入对比张力 (Paul Rand) */
.action-footer {
  padding-bottom: env(safe-area-inset-bottom);
  flex-shrink: 0;
  display: flex;
  justify-content: center;
}

.confirm-trigger {
  background: #000;
  color: #fff;
  border-radius: 24rpx; /* Apple 风格微圆角 */
  height: 110rpx;
  display: flex; /* 修复文字对齐 */
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  width: 85% !important; /* 重新锚定宽度 */
  margin-top: 60rpx; /* 紧贴上方数据面板 */
  border: none;
}

.confirm-trigger::after {
  display: none;
}

.confirm-trigger:active {
  opacity: 0.8;
  transform: scale(0.995);
}
