<view class="container">
  <!-- Precision Custom Header -->
  <view class="safe-header" style="height: {{navHeight}}px;">
    <view class="header-main" style="top: {{menuTop}}px; height: {{menuHeight}}px; right: {{menuRight}}px;">
      <view class="header-title-group">
        <text class="page-label">DASHBOARD</text>
        <text class="page-title">Dietary Intake</text>
      </view>
      <view class="header-actions">
        <view class="icon-btn" bindtap="toggleTargetModal" style="height: {{menuHeight}}px; width: {{menuHeight}}px;">
          <text class="icon-settings-text">SET</text>
        </view>
      </view>
    </view>
  </view>

  <view class="content-body" style="padding-top: {{navHeight + 8}}px;">
    <!-- Precision Metrics: Pro Rings -->
    <view class="rings-terminal">
      <view class="ring-unit" wx:for="{{['p', 'c', 'f']}}" wx:key="*this" wx:for-item="key">
        <view class="ring-shell">
          <view class="ring-canvas" style="background: conic-gradient({{key === 'p' ? '#007AFF' : (key === 'c' ? '#FF9500' : '#34C759')}} {{percentages[key] + '%'}}, #F2F2F7 0deg);">
            <view class="ring-core">
              <text class="ring-pct">{{percentages[key]}}%</text>
            </view>
          </view>
        </view>
        <view class="ring-info">
          <text class="ring-label">{{key === 'p' ? 'PRO' : (key === 'c' ? 'CARB' : 'FAT')}}</text>
          <text class="ring-val">{{intake[key]}}g</text>
        </view>
      </view>
    </view>

    <!-- Composer: Log Entry -->
    <view class="composer-section">
      <view class="composer-card">
        <view class="composer-header">
          <text class="section-title">Log Entry</text>
          <view class="reset-trigger" bindtap="resetTodayData">RESET</view>
        </view>
        
        <view class="segmented-control">
          <view 
            wx:for="{{customCategories}}" 
            wx:key="*this"
            class="segment-item {{currentCatIdx === index ? 'active' : ''}}"
            bindtap="selectCategory"
            data-idx="{{index}}"
          >
            {{item}}
          </view>
        </view>

        <view class="input-matrix">
          <view class="input-group main-picker">
            <text class="input-label">FOOD ITEM</text>
            <picker mode="selector" range="{{foodDatabase[currentCatIdx].items}}" range-key="name" value="{{currentFoodIdx}}" bindchange="onFoodChange">
              <view class="picker-value" bindlongpress="onLongPressLibraryItem">
                {{foodDatabase[currentCatIdx].items[currentFoodIdx].name || 'Select food'}}
                <text class="chevron-v">v</text>
              </view>
            </picker>
          </view>

          <view class="input-group weight-input">
            <text class="input-label">AMOUNT</text>
            <view class="amount-field">
              <input type="digit" placeholder="0" bindinput="onWeightInput" value="{{inputValue}}" />
              <text class="unit">g</text>
            </view>
          </view>
        </view>

        <view class="projection-strip" wx:if="{{calcResult.p > 0 || calcResult.c > 0 || calcResult.f > 0}}">
          <view class="proj-item">P <text>+{{calcResult.p}}</text></view>
          <view class="proj-item">C <text>+{{calcResult.c}}</text></view>
          <view class="proj-item">F <text>+{{calcResult.f}}</text></view>
        </view>

        <view class="action-btn-container">
          <button class="primary-action-centered" bindtap="addIntake">LOG INTAKE</button>
        </view>
        
        <view class="history-peek" wx:if="{{lastRecord}}">
        
          <text class="peek-label">LAST LOG</text>
          <text class="peek-value">{{lastRecord}}</text>
        </view>
      </view>
    </view>

    <!-- Quick Converter Section -->
    <view class="quick-converter">
      <view class="converter-card">
     <view class="converter-controls">
          <view class="control-group type-picker">
            <text class="input-label">CATEGORY</text>
            <picker bindchange="onConvertTypeChange" value="{{convertIdx}}" range="{{displayConverters}}">
              <view class="picker-value-mini" bindlongpress="onLongPressConverter">
                {{displayConverters[convertIdx]}}
                <text class="chevron-v">v</text>
              </view>
            </picker>
          </view>
          
          <view class="control-group value-input">
            <text class="input-label">WEIGHT (G/两)</text>
            <input type="digit" placeholder="0" bindinput="onConvertInput" value="{{convertInput}}" />
          </view>
        </view>

        <view class="converter-result-area">
          <text class="result-label">CALCULATED RESULT</text>
          <view class="result-display">
            <text class="result-num">{{convertResult}}</text>
            <text class="result-unit">{{convertUnit}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Redesigned Target Modal -->
  <view class="modal-overlay" wx:if="{{showTargetModal}}" bindtap="toggleTargetModal">
    <view class="modal-content-pro" catchtap="noop">
      <view class="modal-top-bar">
        <text class="modal-title-bold">Daily Targets</text>
        <view class="close-x-btn" bindtap="toggleTargetModal">✕</view>
      </view>
      
      <view class="target-editor-grid">
        <view class="editor-row" wx:for="{{['p', 'c', 'f']}}" wx:key="*this" wx:for-item="k">
          <view class="editor-info">
            <text class="editor-label">{{k === 'p' ? 'Protein' : (k === 'c' ? 'Carbs' : 'Fats')}}</text>
            <text class="editor-sub">Recommended for your activity</text>
          </view>
          <view class="editor-input-box">
            <input type="digit" value="{{tempTargets[k]}}" data-key="{{k}}" bindinput="onTargetInput" />
            <text class="editor-unit">g</text>
          </view>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="save-targets-btn" bindtap="saveCustomTargets">UPDATE DAILY GOALS</button>
      </view>
    </view>
  </view>

  <!-- Custom Converter Modal -->
  <view class="modal-overlay" wx:if="{{showConverterModal}}" bindtap="toggleConverterModal">
    <view class="modal-content-pro" catchtap="noop">
      <view class="modal-top-bar">
        <text class="modal-title-bold">{{newRule.id ? 'Edit Rule' : 'New Rule'}}</text>
        <view class="close-x-btn" bindtap="toggleConverterModal">✕</view>
      </view>
      
      <view class="target-editor-grid">
        <view class="editor-row">
          <view class="editor-info">
            <text class="editor-label">Name</text>
            <text class="editor-sub">e.g. Rice(Cooked/g)</text>
          </view>
          <view class="editor-input-box" style="width: 300rpx;">
            <input type="text" placeholder="Rule name" data-key="name" bindinput="onNewRuleInput" value="{{newRule.name}}" style="width: 100%;" />
          </view>
        </view>

        <view class="editor-row">
          <view class="editor-info">
            <text class="editor-label">Factor</text>
            <text class="editor-sub">Result = Input * Factor</text>
          </view>
          <view class="editor-input-box">
            <input type="digit" placeholder="0.28" data-key="factor" bindinput="onNewRuleInput" value="{{newRule.factor}}" />
          </view>
        </view>

        <view class="editor-row">
          <view class="editor-info">
            <text class="editor-label">Unit</text>
            <text class="editor-sub">Result suffix</text>
          </view>
          <view class="editor-input-box" style="width: 200rpx;">
            <input type="text" placeholder="g carb" data-key="unit" bindinput="onNewRuleInput" value="{{newRule.unit}}" style="width: 100%;" />
          </view>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="save-targets-btn" bindtap="saveConverter">SAVE RULE</button>
      </view>
    </view>
  </view>
</view>
